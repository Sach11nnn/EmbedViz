# EmbedViz Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Groq AI API Key (free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Server Port
PORT=8080

# WebSocket Auth Token (change to any random string in production)
WS_AUTH_TOKEN=change_this_to_a_random_secret

# Node Environment
NODE_ENV=development
